{
  "name": "workbench-core",
  "description": "Core infrastructure for Claude Code: persistent agent identity, session lifecycle hooks, operational memory, and meta skills. Provides a customizable framework where users configure the agent name, memory path, and persona files.",
  "version": "0.1.17",
  "author": {
    "name": "Mike Bronner",
    "url": "https://github.com/mike-bronner"
  },
  "repository": "https://github.com/mike-bronner/core",
  "mcpServers": {
    "memory": {
      "command": "markdown-vault-mcp",
      "args": ["serve"],
      "env": {
        "MARKDOWN_VAULT_MCP_SOURCE_DIR": "",
        "MARKDOWN_VAULT_MCP_INDEX_PATH": "",
        "MARKDOWN_VAULT_MCP_EMBEDDINGS_PATH": "",
        "MARKDOWN_VAULT_MCP_STATE_PATH": "",
        "MARKDOWN_VAULT_MCP_READ_ONLY": "false",
        "MARKDOWN_VAULT_MCP_REQUIRED_FIELDS": "name,type",
        "MARKDOWN_VAULT_MCP_INDEXED_FIELDS": "name,type,tags,summary,date,scope,log_files",
        "MARKDOWN_VAULT_MCP_SERVER_NAME": "workbench-memory",
        "EMBEDDING_PROVIDER": "fastembed"
      }
    }
  }
}
